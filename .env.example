# product-overlord — environment configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# The public base URL of this server (used to build confirm_post_url in Forge envelopes)
# Must be a valid HTTPS URL reachable by Forge and by Jira users' browsers.
BASE_URL=https://your-overlord-host.example.com

# ---------------------------------------------------------------------------
# OPTIONAL — Jira Agile REST adapter
# Without these, Jira ingestion is disabled (degraded mode).
# ---------------------------------------------------------------------------

JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_ACCESS_TOKEN=your-jira-api-token

# ---------------------------------------------------------------------------
# OPTIONAL — Rovo MCP adapter
# Without these, Rovo MCP ingestion is disabled (Jira Agile REST is used as sole adapter).
# ---------------------------------------------------------------------------

ROVO_MCP_CLOUD_ID=your-atlassian-cloud-id
ROVO_MCP_ACCESS_TOKEN=your-rovo-mcp-access-token

# ---------------------------------------------------------------------------
# OPTIONAL — Repository adapters
# Without at least one token, repo grounding is disabled.
# ---------------------------------------------------------------------------

# GitHub Cloud
GITHUB_ACCESS_TOKEN=ghp_your_github_token

# Bitbucket Cloud
BITBUCKET_ACCESS_TOKEN=your-bitbucket-app-password

# ---------------------------------------------------------------------------
# OPTIONAL — Server settings
# ---------------------------------------------------------------------------

PORT=3000
NODE_ENV=production

# ---------------------------------------------------------------------------
# OPTIONAL — Feature flags
# ---------------------------------------------------------------------------

# Set to true to prevent the /forge/output/confirm endpoint from posting to Jira.
# Useful for testing and staged rollouts. Default: false.
SHADOW_MODE=false

# Enable the EAP rovo:agentConnector A2A path.
# Requires EAP approval from Atlassian before enabling in production.
# See AGENTS.md invariant 15. Default: false.
FEATURE_ROVO_AGENT_CONNECTOR=false

# ---------------------------------------------------------------------------
# OPTIONAL — LLM adapter (OpenAI-compatible)
# Without LLM_API_KEY, the system runs in deterministic-only mode (DEGRADED_LLM=true).
# Compatible with OpenAI, Azure OpenAI, Ollama, and any OpenAI-compatible endpoint.
# ---------------------------------------------------------------------------

LLM_API_KEY=sk-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Max LLM calls per minute (default: 60). Excess calls are queued with back-off.
LLM_CALLS_PER_MINUTE=60

# Set to true to disable LLM enrichment and run deterministic-only mode.
# Always true in CI/tests. Default: false.
DEGRADED_LLM=false

# ---------------------------------------------------------------------------
# OPTIONAL — Knowledge Base store
# ---------------------------------------------------------------------------

# Path on disk for the LanceDB vector store (default: ./.kb)
KB_STORE_PATH=./.kb

# Maximum total KB store size in GB before ingestion is rejected (default: 5)
KB_MAX_SIZE_GB=5

# ---------------------------------------------------------------------------
# OPTIONAL — Agent Orchestration UI (stage-7)
# These vars configure the desktop UI backend (ConnectionManager, OrchestratorTeam).
# ---------------------------------------------------------------------------

# Directory for the encrypted credential store used by ConnectionManager.
# On platforms that support Tauri Stronghold, this path holds the Stronghold vault file.
# On other platforms an AES-256-GCM encrypted JSON file is written here.
# Default: ~/.product-overlord/credentials
CREDENTIAL_STORE_PATH=~/.product-overlord/credentials

# Number of repeated progress events on the same stage (without advancing) before
# OrchestratorTeam emits a "thrash" finding. Default: 5.
ORCHESTRATOR_THRASH_THRESHOLD=5

# Seconds of silence from a run before OrchestratorTeam emits a "stall" finding.
# Default: 120 (2 minutes).
ORCHESTRATOR_STALL_TIMEOUT_S=120

# Maximum wall-clock seconds a single workflow run may run before OrchestratorTeam
# emits a "runaway" finding. Default: 600 (10 minutes).
ORCHESTRATOR_RUNAWAY_TIMEOUT_S=600

# ── Desktop UI endpoints ──────────────────────────────────────────────────
# Expose /api/status, /api/config, and /api/metrics (SSE) for the Tauri
# desktop UI. Set to "false" to disable in production deployments that do
# not use the desktop app. Default: true.
UI_DEV_ENDPOINTS=true
